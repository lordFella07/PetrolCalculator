<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/material_dynamic_primary70"
        app:title="Smart Petrol Calculator"
        app:titleTextColor="#FFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Petrol Type:" />

        <Spinner
            android:id="@+id/spinnerPetrolType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/petrol_types"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Petrol price per liter (RM)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fuel usage (liters)"
            android:inputType="numberDecimal" />

        <Switch
            android:id="@+id/switchBudi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUDI MADANI Eligible?"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate"
            android:backgroundTint="@color/material_dynamic_primary70" />/>

        <TextView
            android:id="@+id/tvTotalCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Cost: RM 0.00"
            android:textSize="18sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvRebate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUDI Rebate: RM 0.00"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/tvTotalSaving"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Saving: RM 0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#006600"/>

    </LinearLayout>
</LinearLayout>